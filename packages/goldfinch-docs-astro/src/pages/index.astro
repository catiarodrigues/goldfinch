---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>
  <main class="mx-auto max-w-4xl px-4 py-16">
    <h1 class="mb-4 text-4xl font-bold text-goldfinch-strong">Goldfinch</h1>
    <p class="mb-8 text-lg text-goldfinch-subtle">
      A React component library built on Base UI and Tailwind CSS v4.
    </p>

    <div class="flex gap-4">
      <a
        href="/components/button"
        class="inline-flex items-center rounded-lg bg-goldfinch-brand px-4 py-2 text-sm font-medium text-goldfinch-inverse hover:bg-goldfinch-brand-hover"
      >
        Get Started
      </a>
    </div>
  </main>
</MainLayout>
