---
import MainLayout from "./MainLayout.astro";
import SidebarNav from "../components/SidebarNav.tsx";
const currentPath = Astro.url.pathname;
const headings = Astro.props.headings || [];
const showToc = headings.length > 0;
---

<MainLayout>
  <div slot="head">
    <slot name="head" />
  </div>

  <div class="flex">
    <SidebarNav client:load currentPath={currentPath} />

    <main class="min-w-0 flex-1">
      <div class="mx-auto max-w-5xl px-6 py-10 lg:px-10">
        <article class="goldfinch-prose max-w-none">
          <slot />
        </article>
      </div>
    </main>

    {showToc && (
      <aside class="hidden xl:block w-56 shrink-0 pt-10 pr-4">
        <div class="sticky top-24">
          <h4 class="mb-3 text-xs font-semibold uppercase tracking-wider text-goldfinch-subtle">
            On this page
          </h4>
          <ul class="space-y-1.5">
            {headings.filter((h: any) => h.depth <= 3).map((h: any) => (
              <li>
                <a
                  href={`#${h.slug}`}
                  class={`block text-sm transition-colors hover:text-goldfinch-strong ${
                    h.depth === 3 ? "pl-4" : ""
                  } text-goldfinch-subtle`}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    )}
  </div>
</MainLayout>
